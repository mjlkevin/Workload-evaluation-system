# ============================================================
# apps/api 环境变量模板
# ============================================================
# 实际使用时 copy 为 .env.local（.gitignore 已豁免 .env.example）

# 服务端口
PORT=3000

# JWT
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_IN=8h

# Kimi（Moonshot）
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
KIMI_API_BASE_URL=https://api.moonshot.cn/v1

# PostgreSQL
# 开发库；测试运行时会用独立库 workload_eval_test（不写这里）
DATABASE_URL=postgres://kevin@localhost:5432/workload_eval
DATABASE_POOL_MAX=10
