{
  "name": "workload-evaluation-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm run dev --prefix ui/V0_SAAS",
    "dev:api": "npm run dev -w apps/api",
    "dev:recover": "bash scripts/recover-dev.sh",
    "tunnel:api": "bash scripts/tunnel-api-cloudflared.sh",
    "tunnel:web": "bash scripts/tunnel-web-cloudflared.sh",
    "tunnel:api:ngrok": "bash scripts/tunnel-api-ngrok.sh",
    "tunnel:web:ngrok": "bash scripts/tunnel-web-ngrok.sh",
    "tunnel:api:lt": "bash scripts/tunnel-api-localtunnel.sh",
    "tunnel:web:lt": "bash scripts/tunnel-web-localtunnel.sh",
    "build:web": "npm run build --prefix ui/V0_SAAS",
    "build:api": "npm run build -w apps/api",
    "rules:standardize": "node scripts/standardize-rules-from-excel.js",
    "rules:regression": "node scripts/rule-regression-check.js",
    "rules:excel-report": "node scripts/excel-regression-report.js",
    "test:api:integration": "node scripts/api-integration-check.js",
    "test:api:team": "node scripts/team-api-check.js",
    "test:modules": "npm run test:modules -w apps/api",
    "test:rules": "npm run test:rules -w apps/api",
    "test:integration": "npm run test:integration -w apps/api",
    "ops:backup:config": "node scripts/backup-config.js",
    "ops:check:config": "npm run ops:config:check -w apps/api",
    "ops:check:config:repair": "npm run ops:config:check:repair -w apps/api",
    "test:all": "npm run test:modules && npm run test:rules && npm run test:integration && npm run rules:regression && npm run rules:excel-report",
    "test:e2e:web": "npm run test:e2e --prefix ui/V0_SAAS"
  }
}
